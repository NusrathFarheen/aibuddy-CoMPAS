# AIBuddy Backend Environment Variables

# 1. Database (If left empty, uses local SQLite database)
# Get this from Neon.tech or Supabase
DATABASE_URL=postgresql://user:password@hostname/dbname

# 2. Vector Memory (If left empty, uses local ChromaDB)
# Get this from Pinecone (pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key
# The name of the Pinecone index you created (must have 384 dimensions)
PINECONE_INDEX_NAME=aibuddy

# 3. Image Uploads (If left empty, saves to local /uploads folder)
# Get this from Cloudinary Dashboard
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
